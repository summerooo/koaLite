# .env - 环境配置
# -------------------------------------------------
# 通用设置（开发和生产均使用）
# 服务器主机，可根据环境自行覆盖
# 默认监听端口
# pino 日志级别（debug、info、warn、error 等）
HOST=127.0.0.1            # 服务器主机，可根据环境自行覆盖
PORT=1116                # 默认监听端口
LOG_LEVEL=info           # pino 日志级别（debug、info、warn、error 等）

# 开发环境变量
# 本地运行时请设置 NODE_ENV=development
CORS_ORIGIN_DEV=http://localhost:9527  # 开发环境跨域来源

# 生产环境变量
# 生产服务器请设置 NODE_ENV=production
CORS_ORIGIN_PROD=https://your-production-domain.com  # 生产环境跨域来源

# 下面为额外的秘密变量示例（请勿提交真实密钥）
# JWT_SECRET=your_jwt_secret_here
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# 开发环境变量
# 本地运行时请设置 NODE_ENV=development
# 生产环境变量
# 生产服务器请设置 NODE_ENV=production
# 下面为额外的秘密变量示例（请勿提交真实密钥）
# JWT_SECRET=your_jwt_secret_here
# DATABASE_URL=mysql://user:pass@host:3306/dbname
